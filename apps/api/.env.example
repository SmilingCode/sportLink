NODE_ENV=development
PORT=4000

# PostgreSQL — use Supabase (free tier includes PostGIS)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/sportlink

# Generate a random 32+ char string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# Next.js frontend URL (dev)
FRONTEND_URL=http://localhost:3000

# Stripe — get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio Verify — get from console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_VERIFY_SERVICE_SID=VA...
